# shellcheck shell=bash

# Git branch for prompt
__git_ps1_branch() {
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null)
    [[ -n "$branch" ]] && printf ' (%s)' "$branch"
}

__set_ps1() {
    PS1='\[\e[1;32m\]\h\[\e[0m\]:\[\e[1;34m\]\w\[\e[0;33m\]$(__git_ps1_branch)\[\e[0m\]\$ '
}
PROMPT_COMMAND="__set_ps1${PROMPT_COMMAND:+;$PROMPT_COMMAND}"

# Enable color support
alias ls='ls --color=auto'
alias grep='grep --color=auto'

# jetson-ffmpeg project shortcuts.
# The dev container always mounts the repository at /workspace; the underlying
# scripts resolve their own paths, so these run correctly from any directory.
export JETSON_FFMPEG_ROOT="/workspace"
alias build='"${JETSON_FFMPEG_ROOT}/scripts/build.sh"'           # build libnvmpi
alias ffpatch='"${JETSON_FFMPEG_ROOT}/scripts/ffpatch.sh"'       # patch an ffmpeg tree
alias update-patch='"${JETSON_FFMPEG_ROOT}/ffmpeg/dev/update_patch.sh"'  # regenerate patches
alias try-build='"${JETSON_FFMPEG_ROOT}/ffmpeg/dev/try_build.sh"'        # build-validate all versions
alias hw-test='"${JETSON_FFMPEG_ROOT}/test/hw-test.sh"'          # hardware smoke test
alias init-claude='"${JETSON_FFMPEG_ROOT}/scripts/init-claude.sh"'

# History
HISTSIZE=10000
HISTFILESIZE=20000
HISTCONTROL=ignoreboth:erasedups
shopt -s histappend

# Homebrew
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv 2>/dev/null)"

# nvm
export NVM_DIR="${HOME}/.nvm"
# shellcheck source=/dev/null
[ -s "${NVM_DIR}/nvm.sh" ] && . "${NVM_DIR}/nvm.sh"
# shellcheck source=/dev/null
[ -s "${NVM_DIR}/bash_completion" ] && . "${NVM_DIR}/bash_completion"

# uv / uvx
export PATH="${HOME}/.local/bin:${PATH}"

# Bash completion
if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
fi
